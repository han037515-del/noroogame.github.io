<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>우당탕탕 특약점 페인팅 대작전</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;background:#141a12;overflow:hidden;}
body{display:flex;justify-content:center;align-items:center;
  font-family:system-ui,-apple-system,'Apple SD Gothic Neo','Malgun Gothic',sans-serif;}
/* 스테이지: 시안(1608x3496) 비율 고정 → 핫스팟 좌표가 항상 정확히 맞음 */
#stage{position:relative;height:100vh;max-height:100vh;aspect-ratio:1608/3496;max-width:100vw;
  background:#000;overflow:hidden;user-select:none;touch-action:none;box-shadow:0 0 60px rgba(0,0,0,.6);}
@supports not (aspect-ratio:1){#stage{width:100%;height:100%;}}
.scene{position:absolute;inset:0;display:none;}
.scene.on{display:block;animation:fadein .4s ease;}
@keyframes fadein{from{opacity:0}to{opacity:1}}
.bgimg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;}
.hotspot{position:absolute;background:transparent;border:none;cursor:pointer;z-index:5;}
.hotspot.pulse{animation:pulse 1.4s ease-in-out infinite;border-radius:20px;}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(255,255,255,0)}50%{box-shadow:0 0 0 8px rgba(255,255,255,.28)}}
.tapall{position:absolute;inset:0;z-index:4;cursor:pointer;}
canvas{position:absolute;inset:0;width:100%;height:100%;z-index:3;touch-action:none;}

/* ---- 미니게임 HUD ---- */
.hud{position:absolute;top:0;left:0;right:0;z-index:6;padding:4% 4% 0;display:flex;flex-direction:column;align-items:center;gap:10px;pointer-events:none;}
.hud-row{display:flex;gap:10px;width:100%;justify-content:space-between;font-weight:bold;}
.pill{background:rgba(0,0,0,.66);color:#fff;border-radius:999px;padding:8px 16px;
  font-size:clamp(13px,3.8vh,17px);border:2px solid rgba(255,255,255,.4);}
.pill b{color:#c8f26d;}
.toast{position:absolute;left:50%;top:44%;transform:translate(-50%,-50%);z-index:8;background:rgba(0,0,0,.8);color:#fff;
  padding:16px 26px;border-radius:16px;font-size:clamp(15px,2.2vh,20px);border:2px solid #fff;
  opacity:0;pointer-events:none;transition:opacity .25s;text-align:center;line-height:1.55;font-weight:bold;}
.toast.on{opacity:1;}
.progress-wrap{position:absolute;left:8%;right:8%;bottom:7%;z-index:6;pointer-events:none;
  display:flex;flex-direction:column;align-items:center;gap:8px;}
.progress{width:100%;height:22px;background:rgba(0,0,0,.55);border:3px solid #1c4d26;border-radius:999px;overflow:hidden;}
.progress i{display:block;height:100%;width:0;background:linear-gradient(#c8f26d,#57b647);transition:width .15s;}
#g1-hud .mission-title{color:#b6f04c;font-weight:900;font-size:clamp(22px,3.4vh,34px);letter-spacing:2px;
  text-shadow:-2px 0 #1c4d26,2px 0 #1c4d26,0 -2px #1c4d26,0 3px #1c4d26,0 5px 0 #14381c;}
#g1-hud .mission-badge{background:#fdf7e3;border:3px solid #1c4d26;border-radius:10px;padding:3px 14px;
  font-weight:bold;color:#2e7d3c;font-size:clamp(12px,1.8vh,15px);box-shadow:0 3px 0 #1c4d26;}
#btn-replay{position:absolute;bottom:1.5%;left:50%;transform:translateX(-50%);z-index:6;
  background:rgba(0,0,0,.45);border:1px solid rgba(255,255,255,.5);color:#fff;border-radius:999px;
  font-family:inherit;font-size:13px;padding:6px 16px;cursor:pointer;}
</style>
</head>
<body>
<div id="stage">

  <!-- 1. 타이틀 -->
  <section class="scene on" id="s-title">
    <img class="bgimg" data-src="img1" alt="타이틀">
    <button class="hotspot pulse" id="btn-play" aria-label="PLAY"
      style="left:18%;top:43%;width:64%;height:13%;"></button>
  </section>

  <!-- 2. 대화: 노루페인트 루 -->
  <section class="scene" id="s-d1">
    <img class="bgimg" data-src="img2" alt="노루페인트 루 대사">
    <div class="tapall" data-next="s-d2"></div>
  </section>

  <!-- 3. 대화: 대리점 사장님 -->
  <section class="scene" id="s-d2">
    <img class="bgimg" data-src="img3" alt="대리점 사장님 대사">
    <div class="tapall" data-next="s-g1"></div>
  </section>

  <!-- 4. 미니게임 1: 롤러를 담아라 -->
  <section class="scene" id="s-g1">
    <img class="bgimg" data-src="bg_g1" alt="">
    <canvas id="cv1"></canvas>
    <div class="hud" id="g1-hud">
      <span class="mission-badge">미션 🖌️</span>
      <span class="mission-title">롤러를 담아라</span>
      <div class="hud-row">
        <span class="pill">🖌️ <b id="g1-count">0</b> / 10</span>
        <span class="pill">⏱ <b id="g1-time">30</b>초</span>
      </div>
    </div>
    <div class="toast" id="g1-toast"></div>
  </section>

  <!-- 5. 대화: 이지현 -->
  <section class="scene" id="s-d3">
    <img class="bgimg" data-src="img5" alt="이지현 대사">
    <div class="tapall" data-next="s-g2"></div>
  </section>

  <!-- 6. 미니게임 2: 페인트를 칠해라 -->
  <section class="scene" id="s-g2">
    <img class="bgimg" data-src="img6" alt="페인트를 칠해라">
    <canvas id="cv2"></canvas>
    <div class="progress-wrap">
      <div class="progress"><i id="g2-bar"></i></div>
      <span class="pill">카드 속 벽을 문질러 칠하기! <b id="g2-pct">0%</b></span>
    </div>
    <div class="toast" id="g2-toast"></div>
  </section>

  <!-- 7. 성공 -->
  <section class="scene" id="s-clear">
    <img class="bgimg" data-src="img7" alt="미션 성공">
    <button class="hotspot pulse" id="btn-shop" aria-label="우리집 근처 노루페인트 보기"
      style="left:7%;top:77.5%;width:86%;height:9.5%;"></button>
    <button id="btn-replay">↻ 다시 하기</button>
  </section>
</div>

<script>
const ASSETS={
img1:"data:image/jpeg;base64,",
img2:"data:image/jpeg;base64,",
img3:"data:image/jpeg;base64,",
img4:"data:image/jpeg;base64,",
img5:"data:image/jpeg;base64,",
img6:"data:image/jpeg;base64,",
img7:"data:image/jpeg;base64,",
bg_g1:"data:image/jpeg;base64,",
};

</script>
<script>
(()=>{
'use strict';
const $=s=>document.querySelector(s);
let totalScore=0;

/* 에셋 주입 */
document.querySelectorAll('img[data-src]').forEach(im=>{ im.src=ASSETS[im.dataset.src]; });

/* ---------- 장면 전환 ---------- */
function go(id){
  document.querySelectorAll('.scene').forEach(s=>s.classList.remove('on'));
  $('#'+id).classList.add('on');
  if(id==='s-g1') game1.start();
  if(id==='s-g2') game2.start();
}
$('#btn-play').addEventListener('click',()=>go('s-d1'));
document.querySelectorAll('.tapall').forEach(b=>b.addEventListener('click',()=>go(b.dataset.next)));

/* ---------- 공통 ---------- */
function fitCanvas(cv){
  const r=cv.parentElement.getBoundingClientRect();
  const dpr=Math.min(window.devicePixelRatio||1,2);
  cv.width=r.width*dpr; cv.height=r.height*dpr;
  const ctx=cv.getContext('2d'); ctx.setTransform(dpr,0,0,dpr,0,0);
  return {ctx,w:r.width,h:r.height};
}
function toast(el,msg,ms=1100){el.innerHTML=msg;el.classList.add('on');
  clearTimeout(el._t);el._t=setTimeout(()=>el.classList.remove('on'),ms);}
function rr(ctx,x,y,w,h,r){ctx.beginPath();ctx.roundRect(x,y,w,h,r);}

/* ============================================================
   미니게임 1 — 롤러를 담아라
============================================================ */
const game1=(()=>{
  const cv=$('#cv1'); let ctx,W,H,raf;
  let items,boxX,caught,timeLeft,running,lastSpawn,lastT,timerIv,flash;
  const GOAL=10;

  function drawRoller(x,y,s,rot){
    ctx.save();ctx.translate(x,y);ctx.rotate(rot);
    ctx.fillStyle='#e0442e';ctx.fillRect(-3*s,10*s,6*s,16*s);
    ctx.strokeStyle='#7a1f12';ctx.lineWidth=2;ctx.strokeRect(-3*s,10*s,6*s,16*s);
    ctx.strokeStyle='#9aa0a6';ctx.lineWidth=3;
    ctx.beginPath();ctx.moveTo(0,10*s);ctx.lineTo(0,4*s);ctx.lineTo(8*s,4*s);ctx.stroke();
    ctx.fillStyle='#fdf9ef';ctx.strokeStyle='#8a8a82';ctx.lineWidth=2;
    rr(ctx,-14*s,-10*s,28*s,14*s,5*s);ctx.fill();ctx.stroke();
    ctx.fillStyle='#e8e0cc';rr(ctx,-14*s,-2*s,28*s,4*s,2*s);ctx.fill();
    ctx.restore();
  }
  function drawCan(x,y,s,rot){
    ctx.save();ctx.translate(x,y);ctx.rotate(rot);
    ctx.fillStyle='#f4f1e6';ctx.strokeStyle='#7d7a6e';ctx.lineWidth=2.5;
    rr(ctx,-13*s,-12*s,26*s,26*s,3*s);ctx.fill();ctx.stroke();
    ctx.fillStyle='#3e6fb0';ctx.fillRect(-13*s,4*s,26*s,7*s);
    ctx.fillStyle='#cfcabb';ctx.beginPath();ctx.ellipse(0,-12*s,13*s,4*s,0,0,7);ctx.fill();ctx.stroke();
    ctx.strokeStyle='#8a8a82';ctx.beginPath();ctx.arc(0,-14*s,12*s,3.4,6.0);ctx.stroke();
    ctx.restore();
  }
  function drawTrash(x,y,s,rot){
    ctx.save();ctx.translate(x,y);ctx.rotate(rot);
    ctx.fillStyle='#3b3f46';ctx.strokeStyle='#181a1e';ctx.lineWidth=2.5;
    ctx.beginPath();
    ctx.moveTo(0,-16*s);ctx.quadraticCurveTo(14*s,-8*s,13*s,6*s);
    ctx.quadraticCurveTo(12*s,16*s,0,16*s);ctx.quadraticCurveTo(-12*s,16*s,-13*s,6*s);
    ctx.quadraticCurveTo(-14*s,-8*s,0,-16*s);ctx.closePath();ctx.fill();ctx.stroke();
    ctx.strokeStyle='#8a6b3f';ctx.lineWidth=3;
    ctx.beginPath();ctx.moveTo(-5*s,-14*s);ctx.lineTo(5*s,-12*s);ctx.stroke();
    ctx.fillStyle='rgba(255,255,255,.12)';ctx.beginPath();ctx.ellipse(-4*s,0,5*s,9*s,-.4,0,7);ctx.fill();
    ctx.restore();
  }
  function drawBox(){
    const bw=Math.min(W*0.32,150),bh=bw*0.6,x=boxX-bw/2,y=H-bh-H*0.04;
    ctx.save();
    if(flash>0){ctx.shadowColor=flash===1?'#c8f26d':'#ff5544';ctx.shadowBlur=28;}
    ctx.fillStyle='#c89b62';ctx.strokeStyle='#7a5a2e';ctx.lineWidth=4;
    rr(ctx,x,y,bw,bh,6);ctx.fill();ctx.stroke();
    ctx.fillStyle='#b0813f';
    ctx.beginPath();ctx.moveTo(x,y);ctx.lineTo(x-bw*0.16,y+bh*0.3);ctx.lineTo(x+bw*0.06,y+bh*0.34);ctx.closePath();ctx.fill();ctx.stroke();
    ctx.beginPath();ctx.moveTo(x+bw,y);ctx.lineTo(x+bw+bw*0.16,y+bh*0.3);ctx.lineTo(x+bw-bw*0.06,y+bh*0.34);ctx.closePath();ctx.fill();ctx.stroke();
    ctx.fillStyle='#8f6a33';rr(ctx,x+6,y+6,bw-12,10,4);ctx.fill();
    ctx.restore();
    return {x,y,w:bw,h:bh};
  }
  function spawn(){
    const r=Math.random();
    const type=r<0.45?'roller':r<0.72?'can':'trash';
    items.push({type,x:30+Math.random()*(W-60),y:-40,
      vy:(H*0.00022*10)+(Math.random()*H*0.00016*10),rot:Math.random()*6.3,vr:(Math.random()-.5)*0.06});
  }
  function loop(t){
    if(!running)return;
    const dt=Math.min(t-lastT,50);lastT=t;
    if(t-lastSpawn>Math.max(380,700-(30-timeLeft)*12)){spawn();lastSpawn=t;}
    ctx.clearRect(0,0,W,H);
    const box=drawBox();
    for(let i=items.length-1;i>=0;i--){
      const it=items[i];
      it.y+=it.vy*dt; it.rot+=it.vr;
      const s=Math.min(W,480)/300;
      if(it.type==='roller')drawRoller(it.x,it.y,s,it.rot);
      else if(it.type==='can')drawCan(it.x,it.y,s,it.rot);
      else drawTrash(it.x,it.y,s,it.rot);
      if(it.y>box.y-6 && it.y<box.y+box.h*0.7 && Math.abs(it.x-boxX)<box.w/2){
        items.splice(i,1);
        if(it.type==='roller'){caught++;totalScore+=100;flash=1;
          $('#g1-count').textContent=caught;
          if(caught>=GOAL)return win();}
        else if(it.type==='can'){totalScore+=50;flash=1;toast($('#g1-toast'),'페인트 획득! +50 🎨',650);}
        else{caught=Math.max(0,caught-1);totalScore=Math.max(0,totalScore-50);flash=2;
          $('#g1-count').textContent=caught;
          toast($('#g1-toast'),'앗, 쓰레기봉투! 🗑 -1',700);}
        setTimeout(()=>flash=0,180);
      } else if(it.y>H+50){items.splice(i,1);}
    }
    raf=requestAnimationFrame(loop);
  }
  function win(){
    running=false;clearInterval(timerIv);cancelAnimationFrame(raf);
    toast($('#g1-toast'),'미션 성공! 🎉<br>도구를 모두 챙겼어!',1400);
    setTimeout(()=>go('s-d3'),1500);
  }
  function fail(){
    running=false;clearInterval(timerIv);cancelAnimationFrame(raf);
    toast($('#g1-toast'),'시간 초과! 😵<br>다시 도전!',1300);
    setTimeout(start,1500);
  }
  function pointer(e){
    const rect=cv.getBoundingClientRect();
    const cx=(e.touches?e.touches[0].clientX:e.clientX)-rect.left;
    boxX=Math.max(50,Math.min(W-50,cx));
  }
  cv.addEventListener('pointermove',pointer);
  cv.addEventListener('pointerdown',pointer);
  cv.addEventListener('touchmove',e=>{e.preventDefault();pointer(e);},{passive:false});
  window.addEventListener('keydown',e=>{
    if(!running)return;
    if(e.key==='ArrowLeft')boxX=Math.max(50,boxX-34);
    if(e.key==='ArrowRight')boxX=Math.min(W-50,boxX+34);
  });
  function start(){
    ({ctx,w:W,h:H}=fitCanvas(cv));
    items=[];boxX=W/2;caught=0;timeLeft=30;running=true;flash=0;
    $('#g1-count').textContent=0;$('#g1-time').textContent=timeLeft;
    lastSpawn=0;lastT=performance.now();
    clearInterval(timerIv);
    timerIv=setInterval(()=>{
      timeLeft--;$('#g1-time').textContent=timeLeft;
      if(timeLeft<=0)fail();
    },1000);
    cancelAnimationFrame(raf);
    raf=requestAnimationFrame(loop);
  }
  return {start};
})();

/* ============================================================
   미니게임 2 — 페인트를 칠해라 (시안 6번 카드 영역에 칠하기)
============================================================ */
const game2=(()=>{
  const cv=$('#cv2'); let ctx,W,H;
  let painted,pct,done,pointerOn,px,py,sampleTick,card;

  // 시안 6번 속 카드 영역(비율): left 9.2%, top 20.8%, width 81.6%, height 40.2%
  function cardRect(){return {x:W*0.092,y:H*0.208,w:W*0.816,h:H*0.402};}

  function makePaintLayer(){
    painted=document.createElement('canvas');painted.width=W;painted.height=H;
  }
  function render(rx,ry){
    ctx.clearRect(0,0,W,H);
    ctx.drawImage(painted,0,0,W,H);
    // 카드 테두리 가이드
    ctx.strokeStyle='rgba(255,255,255,.55)';ctx.lineWidth=3;ctx.setLineDash([10,8]);
    rr(ctx,card.x,card.y,card.w,card.h,24);ctx.stroke();ctx.setLineDash([]);
    if(pointerOn||done)drawRollerCursor(rx??px,ry??py);
  }
  function drawRollerCursor(x,y){
    ctx.save();ctx.translate(x,y);ctx.rotate(-.25);
    ctx.fillStyle='#8a5a2e';ctx.fillRect(-5,26,10,30);
    ctx.strokeStyle='#5b3a1e';ctx.lineWidth=3;ctx.strokeRect(-5,26,10,30);
    ctx.strokeStyle='#9aa0a6';ctx.lineWidth=5;
    ctx.beginPath();ctx.moveTo(0,26);ctx.lineTo(0,14);ctx.lineTo(16,14);ctx.stroke();
    ctx.fillStyle='#fdfaf0';ctx.strokeStyle='#8a8a82';ctx.lineWidth=3;
    rr(ctx,-30,-18,60,30,8);ctx.fill();ctx.stroke();
    ctx.fillStyle='#efe8d4';
    for(let d=-22;d<24;d+=11){ctx.fillRect(d,12,5,6+Math.random()*5);}
    ctx.restore();
  }
  function clampToCard(x,y){
    return [Math.max(card.x,Math.min(card.x+card.w,x)),
            Math.max(card.y,Math.min(card.y+card.h,y))];
  }
  function paintAt(x,y,x2,y2){
    const c=painted.getContext('2d');
    c.save();
    c.beginPath();c.roundRect(card.x,card.y,card.w,card.h,24);c.clip();
    c.strokeStyle='#f7f3e8';c.lineCap='round';c.lineJoin='round';
    c.lineWidth=Math.min(W,H)*0.17;
    c.beginPath();c.moveTo(x,y);c.lineTo(x2,y2);c.stroke();
    c.strokeStyle='rgba(255,255,255,.7)';c.lineWidth=Math.min(W,H)*0.11;
    c.beginPath();c.moveTo(x,y);c.lineTo(x2,y2);c.stroke();
    c.restore();
  }
  function coverage(){
    const c=painted.getContext('2d');
    const step=12;let hit=0,tot=0;
    const data=c.getImageData(Math.round(card.x),Math.round(card.y),Math.round(card.w),Math.round(card.h)).data;
    const cw=Math.round(card.w);
    for(let y=0;y<Math.round(card.h);y+=step)for(let x=0;x<cw;x+=step){
      tot++;if(data[(y*cw+x)*4+3]>60)hit++;
    }
    return hit/tot;
  }
  function update(){
    pct=Math.min(100,Math.round(coverage()/0.90*100));
    $('#g2-bar').style.width=pct+'%';
    $('#g2-pct').textContent=pct+'%';
    if(pct>=100&&!done){
      done=true;
      const c=painted.getContext('2d');
      c.save();c.beginPath();c.roundRect(card.x,card.y,card.w,card.h,24);c.clip();
      c.fillStyle='#f7f3e8';c.fillRect(card.x,card.y,card.w,card.h);c.restore();
      render();
      totalScore+=500;
      toast($('#g2-toast'),'반짝반짝 새 벽 완성! ✨',1400);
      setTimeout(()=>go('s-clear'),1500);
    }
  }
  function getXY(e){
    const r=cv.getBoundingClientRect();
    const t=e.touches?e.touches[0]:e;
    return clampToCard(t.clientX-r.left,t.clientY-r.top);
  }
  function down(e){if(done)return;pointerOn=true;[px,py]=getXY(e);paintAt(px,py,px,py);render();}
  function move(e){
    if(!pointerOn||done)return;
    const [x,y]=getXY(e);
    paintAt(px,py,x,y);px=x;py=y;render(x,y);
    if(++sampleTick%6===0)update();
  }
  function up(){if(done)return;pointerOn=false;update();render();}
  cv.addEventListener('pointerdown',down);
  cv.addEventListener('pointermove',move);
  window.addEventListener('pointerup',up);
  cv.addEventListener('touchstart',e=>{e.preventDefault();down(e);},{passive:false});
  cv.addEventListener('touchmove',e=>{e.preventDefault();move(e);},{passive:false});
  cv.addEventListener('touchend',up);

  function start(){
    ({ctx,w:W,h:H}=fitCanvas(cv));
    W=Math.round(W);H=Math.round(H);
    card=cardRect();
    done=false;pointerOn=false;pct=0;sampleTick=0;
    px=card.x+card.w/2;py=card.y+card.h/2;
    $('#g2-bar').style.width='0%';$('#g2-pct').textContent='0%';
    makePaintLayer();render();
    toast($('#g2-toast'),'카드 속 벽을 꾹 누르고<br>문질러 봐! 🖌️',1600);
  }
  return {start};
})();

/* ---------- 성공 ---------- */
$('#btn-shop').addEventListener('click',()=>{
  window.open('https://map.naver.com/p/search/'+encodeURIComponent('노루페인트'),'_blank');
});
$('#btn-replay').addEventListener('click',()=>{
  totalScore=0;go('s-title');
});
window.addEventListener('resize',()=>{
  const on=document.querySelector('.scene.on');
  if(on&&on.id==='s-g1')game1.start();
  if(on&&on.id==='s-g2')game2.start();
});
})();
</script>
</body>
</html>
